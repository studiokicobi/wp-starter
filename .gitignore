# Dependencies
/node_modules/
/vendor/

# Build artifacts: committed in this template (matches upstream them.es/starter-fse).
# Generated projects can flip this if they add a CI build step.

# OS / editor
.DS_Store
*.log
.idea/
.vscode/

# Local environment / secrets
.env
.env.*
!.env.example

# wp-env
.wp-env.override.json

# Composer auth (ACF Pro endpoint, private Composer repos)
auth.json

# Composer / PHPStan / PHPCS caches
/.phpunit.cache/
/.phpcs-cache
/phpstan-baseline.neon.bak

# Local settings overrides
/.claude/settings.local.json
