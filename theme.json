{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"customTemplates": [
		{
			"name": "page-notitle",
			"title": "Page: No title",
			"postTypes": [ "page" ]
		}
	],
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		},
		{
			"area": "uncategorized",
			"name": "query",
			"title": "Query (The Loop)"
		}
	],
	"settings": {
		"appearanceTools": true,
		"color": {
			"link": true,
			"defaultPalette": false,
			"palette": [
				{
					"name": "Black",
					"slug": "black",
					"color": "#000000"
				},
				{
					"name": "Dark-Gray",
					"slug": "dark-gray",
					"color": "#212529"
				},
				{
					"name": "Gray",
					"slug": "gray",
					"color": "#ABB8C3"
				},
				{
					"name": "Charcoal",
					"slug": "charcoal",
					"color": "#264653"
				},
				{
					"name": "Green",
					"slug": "green",
					"color": "#2A9D8F"
				},
				{
					"name": "Yellow",
					"slug": "yellow",
					"color": "#E9C46A"
				},
				{
					"name": "Orange",
					"slug": "orange",
					"color": "#F4A261"
				},
				{
					"name": "Red",
					"slug": "red",
					"color": "#E76F51"
				},
				{
					"name": "White",
					"slug": "white",
					"color": "#FFFFFF"
				},
				{
					"name": "Base",
					"slug": "base",
					"color": "var(--wp--preset--color--white)"
				},
				{
					"name": "Primary",
					"slug": "primary",
					"color": "var(--wp--preset--color--black)"
				},
				{
					"name": "Secondary",
					"slug": "secondary",
					"color": "var(--wp--preset--color--dark-gray)"
				},
				{
					"name": "Foreground",
					"slug": "foreground",
					"color": "var(--wp--preset--color--black)"
				},
				{
					"name": "Background",
					"slug": "background",
					"color": "var(--wp--preset--color--white)"
				}
			]
		},
		"layout": {
			"contentSize": "650px",
			"wideSize": "1200px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Small",
					"size": "1rem",
					"slug": "30"
				},
				{
					"name": "Medium",
					"size": "1.5rem",
					"slug": "40"
				},
				{
					"name": "Large",
					"size": "1.75rem",
					"slug": "50"
				},
				{
					"name": "X-Large",
					"size": "2rem",
					"slug": "60"
				},
				{
					"name": "2X-Large",
					"size": "3rem",
					"slug": "70"
				},
				{
					"name": "3X-Large",
					"size": "5rem",
					"slug": "80"
				}
			],
			"units": [ "%", "px", "em", "rem", "vh", "vw" ]
		},
		"typography": {
			"lineHeight": true,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, \"Noto Sans\", \"Liberation Sans\", sans-serif",
					"name": "Sans Serif",
					"slug": "sans-serif"
				},
				{
					"fontFamily": "Cambria, Georgia, \"Times New Roman\", Times, serif",
					"name": "Serif",
					"slug": "serif"
				},
				{
					"fontFamily": "SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
					"name": "Monospace",
					"slug": "monospace"
				}
			],
			"fontSizes": [
				{
					"size": "1rem",
					"slug": "small"
				},
				{
					"size": "1.125rem",
					"slug": "medium",
					"fluid": {
						"min": "1rem",
						"max": "1.125rem"
					}
				},
				{
					"size": "1.75rem",
					"slug": "large",
					"fluid": {
						"min": "1.375rem",
						"max": "1.75rem"
					}
				},
				{
					"size": "2.25rem",
					"slug": "x-large",
					"fluid": {
						"min": "1.75rem",
						"max": "2.25rem"
					}
				},
				{
					"size": "2.75rem",
					"slug": "huge",
					"fluid": {
						"min": "2.25rem",
						"max": "2.75rem"
					}
				},
				{
					"size": "3.25rem",
					"slug": "gigantic",
					"fluid": {
						"min": "2.75rem",
						"max": "3.25rem"
					}
				},
				{
					"size": "6.25rem",
					"slug": "colossal",
					"fluid": {
						"min": "3.25rem",
						"max": "6.25rem"
					}
				}
			]
		},
		"useRootPaddingAwareAlignments": true,
		"custom": {
			"typography": {
				"line-height": {
					"body": 1.7,
					"heading": 1.3,
					"page-title": 1.1
				},
				"font-weight": {
					"light": "300",
					"normal": "400"
				}
			},
			"radius": {
				"sm": "4px",
				"md": "8px",
				"lg": "16px",
				"pill": "9999px"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--white)",
			"text": "var(--wp--preset--color--dark-gray)"
		},
		"elements": {
			"button": {
				"border": {
					"width": "1px",
					"color": "transparent",
					"style": "solid",
					"radius": "0px"
				},
				"color": {
					"background": "var(--wp--preset--color--dark-gray)",
					"text": "var(--wp--preset--color--white)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "var(--wp--custom--typography--font-weight--normal)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--gray)",
						"text": "var(--wp--preset--color--white)"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--gray)",
						"text": "var(--wp--preset--color--white)"
					}
				},
				":active": {
					"color": {
						"background": "var(--wp--preset--color--gray)",
						"text": "var(--wp--preset--color--white)"
					}
				},
				":focus-visible": {
					"color": {
						"background": "var(--wp--preset--color--gray)",
						"text": "var(--wp--preset--color--white)"
					},
					"outline": {
						"color": "var(--wp--preset--color--dark-gray)",
						"style": "solid",
						"width": "2px",
						"offset": "2px"
					}
				},
				":visited": {
					"color": {
						"background": "var(--wp--preset--color--gray)",
						"text": "var(--wp--preset--color--white)"
					}
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--dark-gray)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"typography": {
						"textDecoration": "underline"
					}
				},
				":focus-visible": {
					"outline": {
						"color": "var(--wp--preset--color--dark-gray)",
						"style": "solid",
						"width": "2px",
						"offset": "2px"
					}
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontSize": "var(--wp--preset--font-size--colossal)",
					"lineHeight": "var(--wp--custom--typography--line-height--page-title)",
					"fontWeight": "var(--wp--custom--typography--font-weight--normal)"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontSize": "var(--wp--preset--font-size--gigantic)",
					"lineHeight": "var(--wp--custom--typography--line-height--heading)",
					"fontWeight": "var(--wp--custom--typography--font-weight--normal)"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontSize": "var(--wp--preset--font-size--huge)",
					"lineHeight": "var(--wp--custom--typography--line-height--heading)",
					"fontWeight": "var(--wp--custom--typography--font-weight--normal)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"lineHeight": "var(--wp--custom--typography--line-height--heading)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"lineHeight": "var(--wp--custom--typography--line-height--heading)"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"lineHeight": "var(--wp--custom--typography--line-height--heading)"
				}
			}
		},
		"blocks": {
			"core/post-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontSize": "var(--wp--preset--font-size--colossal)",
					"lineHeight": "var(--wp--custom--typography--line-height--page-title)",
					"fontWeight": "var(--wp--custom--typography--font-weight--normal)"
				}
			},
			"core/query-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontSize": "var(--wp--preset--font-size--gigantic)",
					"lineHeight": "var(--wp--custom--typography--line-height--heading)",
					"fontWeight": "var(--wp--custom--typography--font-weight--normal)"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--sans-serif)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontWeight": "var(--wp--custom--typography--font-weight--normal)"
				}
			},
			"core/pullquote": {
				"border": {
					"width": "0",
					"style": "none"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"lineHeight": "var(--wp--custom--typography--line-height--heading)"
				}
			}
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"top": "var(--wp--preset--spacing--30)",
				"right": "var(--wp--preset--spacing--40)",
				"bottom": "var(--wp--preset--spacing--30)",
				"left": "var(--wp--preset--spacing--40)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans-serif)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "var(--wp--custom--typography--line-height--body)"
		}
	}
}
