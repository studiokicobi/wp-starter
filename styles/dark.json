{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"title": "Dark",
	"settings": {
		"color": {
			"palette": [
				{
					"name": "Base",
					"slug": "base",
					"color": "#000000"
				},
				{
					"name": "Contrast",
					"slug": "contrast",
					"color": "#FFFFFF"
				},
				{
					"name": "Contrast 2",
					"slug": "contrast-2",
					"color": "#FFFFFF"
				},
				{
					"name": "Contrast 3",
					"slug": "contrast-3",
					"color": "#ABB8C3"
				},
				{
					"name": "Contrast 4",
					"slug": "contrast-4",
					"color": "#264653"
				},
				{
					"name": "Accent",
					"slug": "accent",
					"color": "#2A9D8F"
				},
				{
					"name": "Accent 2",
					"slug": "accent-2",
					"color": "#E9C46A"
				},
				{
					"name": "Accent 3",
					"slug": "accent-3",
					"color": "#F4A261"
				},
				{
					"name": "Accent 4",
					"slug": "accent-4",
					"color": "#E76F51"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast-2)"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var(--wp--preset--color--contrast)",
					"text": "var(--wp--preset--color--base)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--accent-2)",
						"text": "var(--wp--preset--color--base)"
					}
				},
				":focus": {
					"color": {
						"background": "var(--wp--preset--color--accent-2)",
						"text": "var(--wp--preset--color--base)"
					}
				},
				":active": {
					"color": {
						"background": "var(--wp--preset--color--accent-2)",
						"text": "var(--wp--preset--color--base)"
					}
				},
				":focus-visible": {
					"outline": {
						"color": "var(--wp--preset--color--contrast)",
						"style": "solid",
						"width": "2px",
						"offset": "2px"
					}
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--accent-2)"
				},
				":hover": {
					"typography": {
						"textDecoration": "underline"
					}
				},
				":focus-visible": {
					"outline": {
						"color": "var(--wp--preset--color--contrast)",
						"style": "solid",
						"width": "2px",
						"offset": "2px"
					}
				}
			}
		}
	}
}
